    "   \"source\": [\n",
    "    \"## Welcome!\\n\",\n",
    "    \"\\n\",\n",
    "    \"Hey there! Ready for the first lesson?\\n\",\n",
    "    \"\\n\",\n",
    "    \"The dfply package makes it possible to do R's dplyr-style data manipulation with pipes in python on pandas DataFrames.\\n\",\n",
